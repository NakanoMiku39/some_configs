#!/usr/bin/env bash
set -euo pipefail

mode=${1:-}

case "$mode" in
  --staged|--all)
    ;;
  *)
    printf 'usage: %s (--staged|--all)\n' "$0" >&2
    exit 2
    ;;
esac

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

fail=0

print_error() {
  printf 'secret-check: %s\n' "$*" >&2
}

is_internal_check_file() {
  local path=$1

  case "$path" in
    .githooks/*|.github/workflows/secret-check.yml)
      return 0
      ;;
  esac

  return 1
}

is_sensitive_path() {
  local path=$1

  case "$path" in
    *.asc|*.gpg|*.kdbx|*.key|*.pem|*.p12|*.pfx|*.token|*.secret)
      return 0
      ;;
    */.env|*/.env.*|.env|.env.*)
      return 0
      ;;
    */.secrets|*/.secrets.*|.secrets|.secrets.*)
      return 0
      ;;
    */id_rsa|*/id_ed25519|*/id_ecdsa|id_rsa|id_ed25519|id_ecdsa)
      return 0
      ;;
    */.ssh/*|.ssh/*|*/.gnupg/*|.gnupg/*|*/.password-store/*|.password-store/*)
      return 0
      ;;
    *github_personal_access_token*|*github-recovery-codes*|*github_recovery_codes*|*wallets/*)
      return 0
      ;;
  esac

  return 1
}

is_text_file() {
  local path=$1

  if [[ "$mode" == "--staged" ]]; then
    git show ":$path" 2>/dev/null | LC_ALL=C grep -Iq .
  else
    LC_ALL=C grep -Iq . "$path"
  fi
}

file_content() {
  local path=$1

  if [[ "$mode" == "--staged" ]]; then
    git show ":$path" 2>/dev/null
  else
    cat -- "$path"
  fi
}

has_sensitive_content() {
  local path=$1
  local content

  is_internal_check_file "$path" && return 1
  is_text_file "$path" || return 1

  content=$(file_content "$path" 2>/dev/null || true)

  grep -Eiq 'BEGIN (OPENSSH|RSA|DSA|EC|PGP) PRIVATE KEY' <<<"$content" && return 0
  grep -Eiq '(^|[[:space:]])(OPENAI_API_KEY|ANTHROPIC_API_KEY|ANTHROPIC_AUTH_TOKEN|GITHUB_TOKEN|HF_TOKEN|HUGGINGFACE_TOKEN)[[:space:]]*=' <<<"$content" && return 0
  grep -Eiq '(^|[[:space:]])[A-Z0-9_]*(API_KEY|AUTH_TOKEN|ACCESS_TOKEN|SECRET_KEY)[[:space:]]*=' <<<"$content" && return 0
  grep -Eiq '(^|[^[:alnum:]_-])sk-[A-Za-z0-9_-]{32,}' <<<"$content" && return 0
  grep -Eiq 'gh[pousr]_[A-Za-z0-9_]{20,}' <<<"$content" && return 0
  grep -Eiq 'github_pat_[A-Za-z0-9_]{20,}' <<<"$content" && return 0
  grep -Eiq 'hf_[A-Za-z0-9]{20,}' <<<"$content" && return 0

  return 1
}

check_path() {
  local path=$1

  if is_internal_check_file "$path"; then
    return
  fi

  if is_sensitive_path "$path"; then
    print_error "refusing sensitive-looking path: $path"
    fail=1
    return
  fi

  if has_sensitive_content "$path"; then
    print_error "refusing possible secret in: $path"
    fail=1
  fi
}

if [[ "$mode" == "--staged" ]]; then
  while IFS= read -r -d '' path; do
    check_path "$path"
  done < <(git diff --cached --name-only --diff-filter=ACMR -z)
else
  while IFS= read -r -d '' path; do
    check_path "$path"
  done < <(git ls-files -z)
fi

if (( fail != 0 )); then
  cat >&2 <<'MSG'

Move machine-local values and secrets to an untracked file, for example:
  ~/.zshrc.local
  ~/.secrets.zsh

If this is a deliberate false positive, bypass the local hook with:
  git commit --no-verify

GitHub Actions will still run this check on pushed commits and pull requests.
MSG
  exit 1
fi
